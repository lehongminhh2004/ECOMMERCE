{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:server": "ts-node ./src/index.ts",
    "dev:worker": "ts-node ./src/index-worker.ts",
    "dev:dashboard": "vite --clearScreen false",
    "dev": "concurrently --kill-others npm:dev:*",
    "enable:usd": "ts-node ./src/scripts/enable-usd-currency.ts",
    "reindex:search": "ts-node ./src/scripts/reindex-search.ts",
    "migration:run": "node ./dist/index.js --run-migrations",
    "build": "tsc",
    "build:dashboard": "vite build",
    "start:server": "node ./dist/index.js",
    "start:worker": "node ./dist/index-worker.js",
    "start": "concurrently npm:start:*"
  },
  "dependencies": {
    "@vendure/asset-server-plugin": "3.6.4",
    "@vendure/core": "3.6.4",
    "@vendure/dashboard": "3.6.4",
    "@vendure/email-plugin": "3.6.4",
    "@vendure/graphiql-plugin": "3.6.4",
    "dotenv": "17.4.2",
    "pg": "8.21.0"
  },
  "devDependencies": {
    "@vendure/cli": "3.6.4",
    "concurrently": "9.2.1",
    "ts-node": "10.9.2",
    "typescript": "5.8.2",
    "vite": "7.3.5"
  }
}
