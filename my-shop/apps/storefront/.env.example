# ─── Vendure Shop API (required) ─────────────────────────────────────────────
# Server-side only (recommended for security)
VENDURE_SHOP_API_URL=http://localhost:3000/shop-api
# Also expose publicly if needed by client components (e.g. coupon apply)
NEXT_PUBLIC_VENDURE_SHOP_API_URL=http://localhost:3000/shop-api

# ─── Payload CMS API (required) ──────────────────────────────────────────────
# Server-side URL (used by Next.js SSR/RSC on server)
PAYLOAD_API_URL=http://localhost:3002/api
# Public URL (used by client components & media image src)
NEXT_PUBLIC_PAYLOAD_API_URL=http://localhost:3002/api
# Base URL for Payload media (without /api suffix)
NEXT_PUBLIC_PAYLOAD_URL=http://localhost:3002

# ─── Vendure Channel Token (optional) ─────────────────────────────────────────
VENDURE_CHANNEL_TOKEN=__default_channel__
NEXT_PUBLIC_VENDURE_CHANNEL_TOKEN=__default_channel__

# ─── Site Metadata ────────────────────────────────────────────────────────────
# Public URL of this storefront (used for SEO/OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# Store display name (optional, defaults to "Vendure Store")
# NEXT_PUBLIC_SITE_NAME=My Shop

# ─── Cache Revalidation ───────────────────────────────────────────────────────
# Secret used by Payload CMS to trigger Next.js on-demand revalidation
# Generate with: openssl rand -base64 32
REVALIDATION_SECRET=your-secure-random-string-here

# ─── Auth & Tokens (optional, defaults provided) ─────────────────────────────
# Cookie name for storing Vendure auth token
# VENDURE_AUTH_TOKEN_COOKIE=vendure-auth-token
# Header name for Vendure auth token
# VENDURE_AUTH_TOKEN_HEADER=vendure-auth-token
# Header name for Vendure channel token
# VENDURE_CHANNEL_TOKEN_HEADER=vendure-token

# ─── Timeouts (optional) ──────────────────────────────────────────────────────
# Fetch timeout in milliseconds. Default 15000 (15s) to handle Render cold starts.
# VENDURE_FETCH_TIMEOUT_MS=15000
# PAYLOAD_FETCH_TIMEOUT_MS=15000

# ─── Production (Vercel + Render) ─────────────────────────────────────────────
# On Vercel, replace localhost URLs with your Render service URLs:
# VENDURE_SHOP_API_URL=https://your-vendure.onrender.com/shop-api
# NEXT_PUBLIC_VENDURE_SHOP_API_URL=https://your-vendure.onrender.com/shop-api
# PAYLOAD_API_URL=https://your-payload.onrender.com/api
# NEXT_PUBLIC_PAYLOAD_API_URL=https://your-payload.onrender.com/api
# NEXT_PUBLIC_PAYLOAD_URL=https://your-payload.onrender.com
# NEXT_PUBLIC_SITE_URL=https://your-storefront.vercel.app
