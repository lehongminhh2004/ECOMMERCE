# Free-tier deployment environment reference.
# Do NOT commit real secret values — copy this file and fill in real values
# on Vercel / Render dashboards.

# ── Shared ────────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_ENV=prod
REVALIDATION_SECRET=replace-with-a-long-random-secret   # openssl rand -base64 32

# ── Vendure on Render ─────────────────────────────────────────────────────────
# Run server + worker together in one Render free-tier instance.
# Set to "false" only if you have a paid plan and want a separate worker service.
RUN_WORKER_IN_PROCESS=true

COOKIE_SECRET=replace-with-a-long-random-secret         # openssl rand -base64 32
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=replace-with-a-strong-password

DATABASE_URL=postgres://user:password@host/database?sslmode=require
DB_SSL=true
DB_SCHEMA=public
DB_SYNCHRONIZE=false
VENDURE_DB_POOL_MAX=6

# Enable Cloudinary asset storage (set to "local" or omit to use local disk)
ASSET_STORAGE=cloudinary
# Still needed so Vendure dashboard shows correct preview URLs
ASSET_URL_PREFIX=https://your-vendure-render-url.onrender.com/assets

# ── Payload CMS on Render ─────────────────────────────────────────────────────
PAYLOAD_SECRET=replace-with-a-long-random-secret        # openssl rand -base64 32
DATABASE_URI=postgres://user:password@host/database?sslmode=require
PAYLOAD_DB_POOL_MAX=4
# Keep false in production — run migrations explicitly, do NOT auto-push schema.
DB_PUSH=false
STOREFRONT_REVALIDATE_URL=https://your-vercel-storefront.vercel.app/api/revalidate

# ── Storefront on Vercel ──────────────────────────────────────────────────────
VENDURE_SHOP_API_URL=https://your-vendure-render-url.onrender.com/shop-api
NEXT_PUBLIC_VENDURE_SHOP_API_URL=https://your-vendure-render-url.onrender.com/shop-api
PAYLOAD_API_URL=https://your-payload-render-url.onrender.com/api
NEXT_PUBLIC_PAYLOAD_API_URL=https://your-payload-render-url.onrender.com/api
NEXT_PUBLIC_PAYLOAD_URL=https://your-payload-render-url.onrender.com
NEXT_PUBLIC_SITE_URL=https://your-vercel-storefront.vercel.app
NEXT_PUBLIC_SITE_NAME=my-shop
VENDURE_CHANNEL_TOKEN=__default_channel__
# Increase if Render cold starts cause timeouts (default 15000ms)
VENDURE_FETCH_TIMEOUT_MS=20000
PAYLOAD_FETCH_TIMEOUT_MS=20000

# ── Cloudinary (required when ASSET_STORAGE=cloudinary) ──────────────────────
# Used by BOTH Vendure and Payload — use the same account, different folders.
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret
# Per-service folder prefix to separate Vendure vs Payload uploads
CLOUDINARY_FOLDER=my-shop          # override to "vendure-assets" / "payload-cms" per service
